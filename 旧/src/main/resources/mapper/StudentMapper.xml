<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sushepro.mapper.StudentMapper">
    
    <resultMap id="studentMap" type="Student">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="major" property="major"/>
        <result column="grade" property="grade"/>
        <result column="student_id" property="studentId"/>
        <result column="phone" property="phone"/>
    </resultMap>
    
    <select id="findById" parameterType="Integer" resultMap="studentMap">
        SELECT * FROM student WHERE id = #{id}
    </select>
    
    <select id="findByUserId" parameterType="Integer" resultMap="studentMap">
        SELECT * FROM student WHERE user_id = #{userId}
    </select>
    
    <select id="findAll" resultMap="studentMap">
        SELECT * FROM student
    </select>
    
    <insert id="addStudent" parameterType="Student" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student (user_id, name, gender, major, grade, student_id, phone)
        VALUES (#{userId}, #{name}, #{gender}, #{major}, #{grade}, #{studentId}, #{phone})
    </insert>
    
    <update id="updateStudent" parameterType="Student">
        UPDATE student SET
            user_id = #{userId},
            name = #{name},
            gender = #{gender},
            major = #{major},
            grade = #{grade},
            student_id = #{studentId},
            phone = #{phone}
        WHERE id = #{id}
    </update>
    
    <delete id="deleteStudent" parameterType="Integer">
        DELETE FROM student WHERE id = #{id}
    </delete>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM student
    </select>

</mapper>